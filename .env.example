# Webcam Stream Configuration
# Copy to .env and fill in your values

# Required
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx

# Theme (matches a file in themes/ directory)
STREAM_THEME=beach

# Flask
FLASK_PORT=8080
FLASK_SECRET_KEY=change-me-to-something-random

# Source cycling interval (seconds, default from theme config)
# CYCLE_INTERVAL=600

# Default music genre (default from theme config)
# DEFAULT_GENRE=instrumental

# Optional — only needed for AI music generation
# ANTHROPIC_API_KEY=sk-ant-...
# SUNO_API_KEY=...
